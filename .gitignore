# Dependências
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# ⚠️ NUNCA commitar arquivos .env com credenciais reais
.env
.env.local
.env.*.local
.env.production

# Banco de dados SQLite (somente dev local)
*.db
*.db-journal
*.db-wal
*.db-shm
apps/backend/prisma/dev.db*

# Certificados e chaves (NUNCA subir para o git)
*.pem
*.p12
*.pfx
*.crt
*.key
*.cer

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Coverage
coverage/
.nyc_output/

# Cache
.cache/
.turbo/
.eslintcache
.stylelintcache
.nest/

# Editor / OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# Netlify
.netlify/

