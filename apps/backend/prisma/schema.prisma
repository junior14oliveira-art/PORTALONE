generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==========================================
// USUÁRIOS E AUTENTICAÇÃO (B2C e B2B / Admin)
// ==========================================
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String?
  role          String    @default("CUSTOMER") // Role: CUSTOMER, ADMIN, MANAGER, STOCK_OPERATOR
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
}

// ==========================================
// CATÁLOGO DE PRODUTOS E CATEGORIAS
// ==========================================
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  
  products    Product[]
}

model Product {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String
  price       Float     // Convertido de Decimal para Float para compatibilidade com SQLite
  categoryId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category    Category  @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  pieces      SerialPiece[] // Se for um computador montado, pode ter peças vinculadas
}

// ==========================================
// RASTREABILIDADE DE PEÇAS 
// ==========================================
model SerialPiece {
  id            String    @id @default(uuid())
  serialNumber  String    @unique // SN Lida pelo leitor de código de barras
  internalCode  String?
  name          String
  type          String    // PieceType: SSD, M2, RAM, CPU, MOTHERBOARD, GPU, PSU, OTHER
  productId     String?   // ID do produto final montado onde esta peça foi alocada (se houver)
  status        String    @default("IN_STOCK") // PieceStatus: IN_STOCK, SEPARATED, MOUNTED, SOLD, RMA
  createdAt     DateTime  @default(now())

  product       Product?  @relation(fields: [productId], references: [id])
}

// ==========================================
// VENDAS (E-commerce e ERP)
// ==========================================
model Order {
  id          String      @id @default(uuid())
  userId      String
  totalAmount Float       // Convertido para Float
  status      String      @default("PENDING") // OrderStatus: PENDING, PAID, PROCESSING, SHIPPED, DELIVERED, CANCELED
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float   // Convertido para Float

  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}
