# PORTALONE — Variáveis de Ambiente (Backend)
# Copie para .env e preencha os valores

# Banco de dados (SQLite para dev, PostgreSQL para produção)
DATABASE_URL="file:./dev.db"
# Para produção com PostgreSQL (Railway, Supabase, etc.):
# DATABASE_URL="postgresql://user:password@host:5432/portalone"

# Porta do servidor
PORT=3001

# URLs dos frontends (para CORS)
ECOMMERCE_URL=https://seusite.netlify.app
ADMIN_URL=https://admin-seusite.netlify.app

# JWT (para autenticação futura)
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_minimo_32_chars
JWT_EXPIRES_IN=7d

# Mercado Pago
# Obtenha em: https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_WEBHOOK_SECRET=sua_chave_webhook_mp

# Correios SIGEP WebService
# Requer contrato corporativo com os Correios
CORREIOS_USER=
CORREIOS_PASSWORD=
CORREIOS_CONTRACT=
CORREIOS_CARD=
CORREIOS_ENV=homologacao

# NF-e (Focus NFe / WebmaniaBR)
NFE_PROVIDER=focus
NFE_API_TOKEN=
NFE_CNPJ=
NFE_ENV=homologacao

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_NUMBER=

# E-mail transacional (futura integração)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PORTALONE <noreply@seusite.com.br>"

# Node environment
NODE_ENV=production
